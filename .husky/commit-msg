#!/usr/bin/env sh
# Advanced commit-msg hook

set -e

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Color codes
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'

echo "${BLUE}📝 Validating commit message...${NC}"

# 1. Jalankan commitlint (Conventional Commits)
pnpm exec commitlint --edit "$COMMIT_MSG_FILE"

# 2. Cegah info sensitif di pesan commit
SENSITIVE='(sk_live_|sk_test_|SUPABASE_(SERVICE_ROLE|ANON_KEY)|SERVICE_ROLE_KEY|password\s*[:=]|api[_-]?key\s*[:=]|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----)'
if echo "$COMMIT_MSG" | grep -iE "$SENSITIVE"; then
  echo "${RED}❌ Commit message mengandung potensi secret/key!${NC}"
  exit 1
fi

# 3. Subject tidak boleh diakhiri titik
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
if echo "$FIRST_LINE" | grep -qE "\.\s*$"; then
  echo "${RED}❌ Subject tidak boleh diakhiri titik.${NC}"
  exit 1
fi

# 4. Subject tidak boleh >72 karakter (diutamakan oleh commitlint, ini double-check)
SUBJECT_LEN=$(echo -n "$FIRST_LINE" | wc -c)
if [ "$SUBJECT_LEN" -gt 72 ]; then
  echo "${YELLOW}⚠️  Subject ${SUBJECT_LEN} karakter (rekomendasi <72)${NC}"
fi

# 5. (Opsional) Paksa referensi issue
# if ! echo "$COMMIT_MSG" | grep -qE "(#[0-9]+|JIRA-[0-9]+|PROJ-[0-9]+)"; then
#   echo "${YELLOW}⚠️  Tidak ada referensi issue (e.g. #123)${NC}"
# fi

# 6. Cegah pesan generik
GENERIC='^(fix|feat|chore):\s*(fix|update|wip|test|stuff|misc|changes?)\s*$'
if echo "$FIRST_LINE" | grep -qiE "$GENERIC"; then
  echo "${RED}❌ Pesan commit terlalu generik. Jelaskan apa yang diubah.${NC}"
  exit 1
fi

echo "${GREEN}✅ Commit message valid!${NC}"